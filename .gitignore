# Python environment (each machine builds its own — never share this)
venv/
__pycache__/
*.pyc
*.pyo

# Local runtime + PERSONAL data (sessions, builds, memory) — per-machine, private
data/

# Backups, scratch, test artifacts
*.bak
*.tmp
studio-research/
verify-*.png

# Build output ZIPs
*.zip

# Native build binary (25MB — ships as a GitHub Release asset via release.ps1, not in git history)
ARKITECT.exe
build/
dist/

# Runtime logs
*.log

# In-app updater working dir (downloaded/staged release + rollback backups)
_update/

# OS junk
Thumbs.db
.DS_Store
desktop.ini
